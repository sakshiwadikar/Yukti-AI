# Server environment variables
# Required: DATABASE_URL, JWT_SECRET
# Required for text generation features: OPENAI_API_KEY or GROQ_API_KEY
# Required for image generation: HF_TOKEN (Hugging Face access token)

PORT=5000
DATABASE_URL=postgresql://your_user:your_password@localhost:5432/yuktiai?schema=public
JWT_SECRET=replace-with-a-long-random-secret
OPENAI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=

# Client environment variables
# Used by the frontend to reach the backend API.
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Firebase configurations
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=