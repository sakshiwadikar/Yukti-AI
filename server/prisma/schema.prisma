generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid()) @map("_id")
  email         String    @unique
  passwordHash  String?
  name          String?
  avatar        String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  subscriptions    Subscription[]
  conversations    Conversation[]
  images           ImageTask[]
  auditLogs        AuditLog[]
  brainstorms      BrainstormHistory[]
  codeHistory      CodeHistory[]
  writingHistory   WritingHistory[]
  recentActivities RecentActivity[]
}

enum Role {
  USER
  ADMIN
  ENTERPRISE
}

model Subscription {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tier      Tier     @default(FREE)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime?
}

enum Tier {
  FREE
  PROFESSIONAL
  ENTERPRISE
}

model Conversation {
  id        String    @id @default(uuid()) @map("_id")
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  title     String?
  module    String    @default("chat")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages  Message[]
}

model Message {
  id             String       @id @default(uuid()) @map("_id")
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String       // "user", "assistant", "system"
  content        String
  createdAt      DateTime     @default(now())
}

model ImageTask {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prompt    String
  url       String?
  status    String   @default("pending") // pending, completed, failed
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model BrainstormHistory {
  id          String   @id @default(uuid()) @map("_id")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  topic       String?
  difficulty  String
  studyMode   String
  sourceType  String
  sourceText  String
  result      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, createdAt])
}

model CodeHistory {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prompt    String
  response  String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model WritingHistory {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prompt    String
  mode      String
  response  String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model RecentActivity {
  id        String   @id @default(uuid()) @map("_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  module    String   // "chat", "image", "brainstorm", "code", "writing"
  activity  String   // the prompt/title text
  timestamp DateTime @default(now())

  @@unique([userId, module])
  @@index([userId, timestamp])
}
