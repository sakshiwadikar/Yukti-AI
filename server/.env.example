# Required server environment variables:
# - DATABASE_URL: PostgreSQL connection string used by Prisma.
# - JWT_SECRET: signs and verifies authentication tokens.
# - OPENAI_API_KEY or GROQ_API_KEY: required for text generation features.
# - HF_TOKEN: Hugging Face token for image generation (direct model inference, not Inference Providers).

PORT=5000
DATABASE_URL="postgresql://your_user:your_password@localhost:5432/yuktiai?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
OPENAI_API_KEY=""
GROQ_API_KEY=""
HF_TOKEN=""
